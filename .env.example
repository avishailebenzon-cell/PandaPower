# WhatsApp proactive-outreach time guard (core/time_guard.py).
# Gates ONLY agent-initiated outreach (Tal/Elad openings, Elad campaigns).
# Inbound auto-replies are never gated. All vars optional — omit to use the
# built-in Israeli defaults (Sun-Thu 8-20, Fri 8-13, Sat + holidays blocked).
#
# Set to "false" to disable gating entirely:
# WHATSAPP_OUTREACH_TIME_GUARD=true
#
# Per-day window [start_hour, end_hour]; null = blocked that day:
# WHATSAPP_SENDING_HOURS={"timezone":"Asia/Jerusalem","schedule":{"sun":[8,20],"mon":[8,20],"tue":[8,20],"wed":[8,20],"thu":[8,20],"fri":[8,13],"sat":null}}
#
# Blocked dates (CSV of MM-DD, replaces the built-in holiday list):
# WHATSAPP_OUTREACH_BLOCKED_DATES=01-01,10-02,12-25

# Frontend Environment Variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:8000
