{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "vite",
  "env": [
    {
      "key": "VITE_API_URL",
      "value": "https://pandapower-backend.onrender.com"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pandapower-backend.onrender.com/:path*"
    }
  ]
}
